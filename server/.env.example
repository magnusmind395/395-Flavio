PORT=3001
NODE_ENV=development

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Firebase Admin (JSON string or path via GOOGLE_APPLICATION_CREDENTIALS)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://magnusmind.app
OPENROUTER_APP_NAME=Magnus Mind

# Web search (use one)
SERPER_API_KEY=
TAVILY_API_KEY=

# WhatsApp Cloud API (stub)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Timeouts (ms)
AXIOS_TIMEOUT=90000
CHAT_TIMEOUT=120000
